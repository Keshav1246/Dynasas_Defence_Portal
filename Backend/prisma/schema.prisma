generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Media {
  id           Int       @id @default(autoincrement())
  fileName     String
  originalName String
  fileUrl      String
  fileType     String
  size         Int
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
}

enum PartnerStatus {
  ACTIVE
  INACTIVE
}

model Partner {
  id          Int           @id @default(autoincrement())
  name        String
  description String?
  logo        String?
  website     String?
  category    String?
  status      PartnerStatus @default(ACTIVE)
  isDeleted   Boolean       @default(false)
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  CLOSED
}

model Inquiry {
  id           Int           @id @default(autoincrement())
  fullName     String
  email        String
  phone        String?
  organization String?
  subject      String
  message      String
  status       InquiryStatus @default(NEW)
  assignedTo   String?
  isDeleted    Boolean       @default(false)
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  action     String
  entityType String
  entityId   String?
  details    String?
  createdAt  DateTime @default(now())
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model CompanyProfile {
  id          String @id @default(uuid())
  companyName String
  overview    String

  // New About Us fields
  foundedYear        String?
  headquarters       String?
  registrationNumber String?
  logo               String?

  // New Mission fields
  missionTitle     String?
  missionStatement String?

  // New Vision fields
  visionTitle     String?
  visionStatement String?
  longTermGoals   String?

  // New Contact fields
  generalEmail          String?
  securityEmail         String?
  mainPhone             String?
  defenseContractsPhone String?
  mailingAddress        String?
  website               String?

  // Relations
  statistics     CompanyStatistic[]
  missionPillars MissionPillar[]
}

model CompanyStatistic {
  id               String         @id @default(uuid())
  label            String
  value            String
  displayOrder     Int            @default(0)
  companyProfileId String
  companyProfile   CompanyProfile @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
}

model MissionPillar {
  id               String         @id @default(uuid())
  text             String
  displayOrder     Int            @default(0)
  companyProfileId String
  companyProfile   CompanyProfile @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
}

model HomepageContent {
  id           String @id @default(uuid())
  heroTitle    String
  heroSubtitle String
  ctaText      String
  ctaLink      String
  heroImage    String

  secondaryCtaText           String?
  secondaryCtaLink           String?
  servicesSectionTitle       String?
  servicesSectionDescription String?
  statisticsSectionTitle     String?

  sectionOrder               String[] @default(["hero", "services", "statistics"])
}

model FooterContent {
  id      String @id @default(uuid())
  address String
  phone   String
  email   String

  footerTagline     String?
  footerDescription String?

  companyLinks  String[]
  solutionLinks String[]
  resourceLinks String[]
  legalLinks    String[]
}

model Service {
  id           String   @id @default(uuid())
  title        String
  description  String
  image        String?
  status       String   @default("published")
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
}

model Settings {
  id String @id @default(uuid())

  // Branding
  primaryColor   String?
  accentColor    String?
  backgroundDark String?
  textColor      String?

  primaryLogo String?
  darkLogo    String?
  favicon     String?

  headingFont String?
  bodyFont    String?

  // Social Media
  linkedinUrl  String?
  twitterUrl   String?
  youtubeUrl   String?
  facebookUrl  String?
  instagramUrl String?

  // Site Settings
  portalName      String?
  siteName        String?
  siteDescription String?
  supportEmail    String?
  supportPhone    String?

  defaultLanguage String? @default("English")
  timezone        String? @default("Asia/Kolkata")
  maintenanceMode Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
